# Copy to .env.production and replace every value before deployment.
# Use only URL-safe characters for POSTGRES_PASSWORD, for example 32+ random hex characters.
POSTGRES_PASSWORD=replace-with-a-long-random-hex-password
PORTFLOW_VERSION=1.0.2
PORTFLOW_SECURE_COOKIES=true

# A real DNS name whose A/AAAA record points to the control server.
PORTFLOW_SITE_ADDRESS=panel.example.com
CADDY_EMAIL=admin@example.com

# Host addresses/ports published by Docker. Check existing listeners before starting.
PORTFLOW_HTTP_BIND=80
PORTFLOW_HTTPS_BIND=443
